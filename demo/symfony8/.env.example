# PORT: host port mapped to FrankenPHP in docker-compose (default demo URL: http://localhost:8013).
PORT=8013

###> symfony/framework-bundle ###
# APP_ENV: Symfony environment (dev/test/prod). Demos use `dev`.
APP_ENV=dev

# APP_DEBUG: enable detailed debug output (`1` in dev, `0` in prod).
APP_DEBUG=1

# FRANKENPHP_MODE: FrankenPHP runtime mode — `classic` (one process per request) or `worker` (long-lived workers).
# Default: worker. Set classic for per-request PHP / easier hot-reload. Recreate with `docker compose up -d` after change.
FRANKENPHP_MODE=worker

# APP_SECRET: signing secret for CSRF and tokens. Use a unique local value; never commit real secrets.
APP_SECRET=change_this_secret_key_to_a_random_value
###< symfony/framework-bundle ###

###> symfony/routing ###
# DEFAULT_URI: base URL for CLI URL generation (must match PORT when using the demo in Docker).
DEFAULT_URI=http://localhost:8013
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# DATABASE_URL: SQLite file for the demo (no external database container required).
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data/demo.db"
###< doctrine/doctrine-bundle ###
